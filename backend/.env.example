# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=True

# API Configuration
API_TITLE=Picoscan Mapping Unit API
API_VERSION=0.1.0
API_DESCRIPTION=API for Picoscan 3D mapping and point cloud processing

# Picoscan Devices Configuration
PICOSCAN_DEVICES_CONFIG=config/picoscans_config.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Database (future use)
DATABASE_URL=sqlite:///./data/picoscan.db

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Processing
MISSING_DATA_INTERPOLATION=True
POINT_CLOUD_PROCESSING_TIMEOUT=300
